---
import Base from "../../layouts/Base.astro";
import { ApiError, apiGet } from "../../lib/api";
import { money } from "../../lib/money";
import { orderStatusLabel } from "../../lib/order-status";

type TrackOrder = {
  orderNumber: string;
  status: string;
  fulfillment: "pickup" | "delivery";
  createdAt: string;
  currency: string;
  subtotalMinor: number;
  shippingMinor: number;
  discountMinor: number;
  totalMinor: number;
  items: { productName: string; quantity: number; lineTotalMinor: number }[];
  statusHistory: { status: string; createdAt: string }[];
};

const { token } = Astro.params;

let order: TrackOrder | null = null;
let notFound = false;
let loadError = false;

try {
  const data = await apiGet<{ order: TrackOrder }>(`/api/v1/track/${token}`);
  order = data.order;
} catch (err) {
  // Mismo criterio que producto/[slug].astro: 404 real vs outage temporal.
  if (err instanceof ApiError && err.status === 404) {
    notFound = true;
  } else {
    loadError = true;
  }
}

if (loadError) {
  Astro.response.status = 502;
} else if (notFound || !order) {
  Astro.response.status = 404;
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("es", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<Base title={order ? `Pedido ${order.orderNumber} · Avanzar` : "Seguimiento · Avanzar"}>
  {
    order ? (
      <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
        <p class="text-sm font-medium text-muted">Pedido</p>
        <h1 class="font-mono text-2xl font-bold tracking-wide text-ink sm:text-3xl">
          {order.orderNumber}
        </h1>
        <p class="mt-1 text-sm text-ink-soft">
          {order.fulfillment === "pickup" ? "Retiro en el local" : "Envío a domicilio"}
          {" · "}
          {formatDate(order.createdAt)}
        </p>

        <div class="mt-8 rounded-2xl border border-line bg-surface p-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">
            Estado
          </h2>
          <ol class="mt-4 flex flex-col gap-4">
            {order.statusHistory.map((h, i) => (
              <li class="flex items-start gap-3">
                <span
                  class={`mt-1 h-2.5 w-2.5 shrink-0 rounded-full ${
                    i === order.statusHistory.length - 1
                      ? "bg-brand-500"
                      : "bg-jade-500"
                  }`}
                  aria-hidden="true"
                />
                <div>
                  <p class="font-semibold text-ink">{orderStatusLabel(h.status)}</p>
                  <p class="text-xs text-muted">{formatDate(h.createdAt)}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="mt-6 rounded-2xl border border-line bg-surface p-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">
            Ítems
          </h2>
          <ul class="mt-4 divide-y divide-line">
            {order.items.map((item) => (
              <li class="flex items-center justify-between py-2 text-sm">
                <span class="text-ink-soft">
                  {item.productName} × {item.quantity}
                </span>
                <span class="font-medium text-ink">
                  {money(item.lineTotalMinor, order.currency)}
                </span>
              </li>
            ))}
          </ul>
          <dl class="mt-4 flex flex-col gap-1.5 border-t border-line pt-4 text-sm">
            <div class="flex justify-between">
              <dt class="text-ink-soft">Subtotal</dt>
              <dd class="text-ink">{money(order.subtotalMinor, order.currency)}</dd>
            </div>
            {order.shippingMinor > 0 && (
              <div class="flex justify-between">
                <dt class="text-ink-soft">Envío</dt>
                <dd class="text-ink">{money(order.shippingMinor, order.currency)}</dd>
              </div>
            )}
            <div class="flex justify-between text-base font-bold">
              <dt class="text-ink">Total</dt>
              <dd class="text-ink">{money(order.totalMinor, order.currency)}</dd>
            </div>
          </dl>
        </div>

        <a
          href={`/api/v1/receipt/${token}`}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600"
        >
          Ver recibo
        </a>
      </section>
    ) : loadError ? (
      <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
        <h1 class="text-2xl font-bold text-ink sm:text-3xl">
          No pudimos cargar tu pedido
        </h1>
        <p class="mt-3 text-muted">
          Hubo un problema al conectar con la tienda. Probá de nuevo en un rato.
        </p>
      </section>
    ) : (
      <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
        <p class="text-6xl font-extrabold tracking-tight text-brand-500">404</p>
        <h1 class="mt-4 text-2xl font-bold text-ink sm:text-3xl">
          Pedido no encontrado
        </h1>
        <p class="mt-3 text-muted">
          Revisá el link de seguimiento que recibiste.
        </p>
        <a
          href="/"
          class="mt-8 inline-flex items-center rounded-full bg-brand-500 px-6 py-3 font-semibold text-white shadow-sm hover:bg-brand-600"
        >
          Ir al inicio
        </a>
      </section>
    )
  }
</Base>
