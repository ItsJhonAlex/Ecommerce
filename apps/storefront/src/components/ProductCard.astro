---
import type { ProductListItem } from "@avanzar/shared";
import { money } from "../lib/money";

interface Props {
  product: ProductListItem;
}

const { product } = Astro.props;
const { slug, name, priceMinor, currency, image, stockQuantity } = product;

const soldOut = stockQuantity === 0;
const href = `/producto/${slug}`;
// Inicial para el placeholder cuando el producto no tiene imagen.
const initial = name.trim().charAt(0).toUpperCase() || "•";
---

<article
  class="group relative flex flex-col overflow-hidden rounded-lg border border-line bg-surface transition-shadow duration-200 hover:shadow-md focus-within:shadow-md"
>
  <div class="relative aspect-square overflow-hidden bg-paper">
    {
      image ? (
        <img
          src={image.url}
          alt={image.alt ?? name}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      ) : (
        <div
          class="grid h-full w-full place-items-center bg-brand-50 text-brand-300"
          aria-hidden="true"
        >
          <span class="text-4xl font-extrabold tracking-tight">{initial}</span>
        </div>
      )
    }

    {
      soldOut && (
        <span class="absolute left-2 top-2 rounded-full bg-ink/85 px-2.5 py-1 text-xs font-semibold text-paper shadow-sm">
          Agotado
        </span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-1 p-3">
    <h3 class="text-sm font-medium leading-snug text-ink">
      <a
        href={href}
        class="after:absolute after:inset-0 hover:text-brand-700 focus-visible:text-brand-700"
      >
        {name}
      </a>
    </h3>
    <p class="mt-auto pt-1 text-base font-bold text-ink">
      {money(priceMinor, currency)}
    </p>
  </div>
</article>
