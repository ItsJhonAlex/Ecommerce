---
import Base from "../layouts/Base.astro";
---

<Base title="Página no encontrada · Avanzar">
  <section
    class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6"
  >
    <p class="text-6xl font-extrabold tracking-tight text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-bold text-ink sm:text-3xl">
      Página no encontrada
    </h1>
    <p class="mt-3 text-muted">
      La página que buscás no existe o se movió. Sigamos avanzando.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-full bg-brand-500 px-6 py-3 font-semibold text-white shadow-sm hover:bg-brand-600"
    >
      Volver al inicio
    </a>
  </section>
</Base>
